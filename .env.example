# Subnet Spirits deployment config — copy to .env (do NOT commit)

# Private key of deployer wallet (testnet first!). 0x prefix optional.
DEPLOYER_PRIVATE_KEY=

# Bittensor EVM RPC endpoints
BITTENSOR_TESTNET_RPC=https://lite.chain.opentensor.ai
BITTENSOR_MAINNET_RPC=https://lite.chain.opentensor.ai

# Unrevealed placeholder URI (the "mystery egg" metadata)
UNREVEALED_URI=ipfs://YOUR_EGG_CID/egg.json

# Optional — for contract verification
ETHERSCAN_API_KEY=
